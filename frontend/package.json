{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "docker:drop-db": "docker exec -it web-app-1 python3 /app/scripts/drop-db.py",
    "docker:init-seed": "docker exec -it web-app-1 python3 /app/scripts/seed-db.py",
    "docker:init-admin":"docker exec -it web-app-1 python3 /app/scripts/init-admin.py",

    "dev:drop-db": "python3 ../scripts/drop-db.py",
    "dev:init-seed": "python3 ../scripts/seed-db.py",
    "dev:init-admin":"python3 ../scripts/init-admin.py",
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.3.0",
    "@tailwindcss/vite": "^4.2.1",
    "axios": "^1.13.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "sockjs-client": "^1.6.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/sockjs-client": "^1.5.4",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
